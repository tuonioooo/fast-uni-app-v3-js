{
  "easycom": {
    // 采用了vue-cli 方式来安装 uv-ui
    "autoscan": true,
    "custom": {
      "^uv-(.*)": "@climblee/uv-ui/components/uv-$1/uv-$1.vue"
    }
  },
  "pages": [
    //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
    {
      "path": "pages/index/index",
      "style": {
        "mp-weixin": {
          "disableScroll": true
        },
        "app-plus": {
          "bounce": "none"
        },
        "mp-alipay": {
          "allowsBounceVertical": "NO"
        },
        "mp-baidu": {
          "disableScroll": true
        }
      }
    },
    {
      "path": "pages/user/user",
      "style": {
        "navigationBarTitleText": ""
      }
    }
  ],
  "tabBar": {
    "color": "#333",
    "selectedColor": "#333",
    "backgroundColor": "#fff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "iconPath": "static/images/tabbar/default/home.png",
        "selectedIconPath": "static/images/tabbar/red/home.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/user/user",
        "iconPath": "static/images/tabbar/default/user.png",
        "selectedIconPath": "static/images/tabbar/red/user.png",
        "text": "我的"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "uni-app",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  }
}